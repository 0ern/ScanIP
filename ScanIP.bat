@ECHO OFF 
:: Batch file for execute Powershell 7 script

TITLE ScanIP

ECHO Checking PowerShell version...

:: Install Powershell 7
winget install --id Microsoft.PowerShell --source winget --disable-interactivity --accept-package-agreements --accept-source-agreements --silent >nul 2>&1

CLS
:: Run script

REM Set current working directory to a temporary folder
cd %TEMP%

REM Execute PowerShell script
pwsh.exe -ExecutionPolicy Bypass -EncodedCommand  -EncodedArguments 

EXIT